# Configuration API Nova
# Clé API pour accéder aux endpoints Nova
NOVA_API_KEY=your-nova-api-key-here

# URLs des environnements Nova
NOVA_URL_PREPROD=https://dashboard-preprod.e-novate.fr
NOVA_URL_PROD=https://dashboard.e-novate.fr

# Port (Railway le fournit automatiquement)
PORT=3000

# Environnement (development, production)
NODE_ENV=production
